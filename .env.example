GROQ_API_KEY=your_groq_api_key_here
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=arxiv-lens
HUGGINGFACE_API_KEY=your_hf_token_here
QDRANT_URL=your_qdrant_cluster_url_here
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=arxiv_papers
BGE_MODEL_NAME=BAAI/bge-m3
GROQ_CLASSIFIER_MODEL=llama-3.1-8b-instant
HF_MODEL=Qwen/Qwen3-8B

# CHANGED: 0.10 → 0.25 (filter chunks before reranking)
SCORE_THRESHOLD=0.25

# NEW: Required for web search fallback
SERPAPI_API_KEY=your_serpapi_key_here

VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi3

# OPTIONAL: Can remove (no longer used since we removed abstract summarization)
OLLAMA_SUMMARIZER_MODEL=phi3

CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=10

# NOTE: Not used anymore (we use threshold >= 6.0 instead of top 3)
# But you can leave it for backwards compatibility
TOP_K_RERANK=3

MAX_HISTORY=5